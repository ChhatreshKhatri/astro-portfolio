---
import RootLayout from "../layouts/RootLayout.astro";
import { Image } from "astro:assets";
import Loading from "../components/Loading.astro";
import { getAboutData } from "../services/api";

const data = await getAboutData();
---

<RootLayout title="Chhatresh Khatri | About" description="Chhatresh Khatri About. Full Stack developer skilled in diverse tech including C/C++, Java, HTML5, CSS3, JavaScript, React.js, Next.js, and more." keywords="" page="about">
  <div class="flex items-center justify-center rounded p-0.5 bg-linear-to-r from-ck1 to-ck2 transition duration-400 ease-out starting:opacity-0 starting:-translate-y-2.5">
    <h1 class="flex justify-center items-center font-semibold tracking-wider text-xl xxs:text-2xl md:text-3xl p-1 px-2 bg-buttonBg dark:bg-darked rounded">About</h1>
  </div>
  {
    data ? (
      <>
        <section class="about-intro-section relative group rounded-lg w-full text-justify p-3 xs:p-6 xs:px-10 transition duration-400 ease-out delay-100 starting:opacity-0 starting:translate-y-2.5" aria-labelledby="about-intro">
          <div class="absolute inset-0 rounded-lg bg-linear-to-r from-blue2/50 to-green2/50 opacity-20 transition-opacity duration-500 group-hover:opacity-50" aria-hidden="true" />
          <article class="relative flex flex-col gap-2 xs:gap-4">
            <h2 id="about-intro" class="about-intro-title text-2xl xxs:text-3xl md:text-4xl text-center transition duration-400 ease-out delay-200 starting:opacity-0 starting:translate-y-2.5">
              {data.content.title}
            </h2>
            <p class="about-intro-text text-md xs:text-xl transition duration-400 ease-out delay-300 starting:opacity-0 starting:translate-y-2.5">{data.content.text}</p>
          </article>
        </section>
        <div class="rounded flex items-center justify-center bg-linear-to-r from-ck1 to-ck2 p-0.5 transition duration-400 ease-out delay-400 starting:opacity-0 starting:scale-[0.98]">
          <h2 class="flex justify-center items-center font-semibold tracking-wider text-xl xxs:text-2xl md:text-3xl p-1 md:px-2 bg-buttonBg dark:bg-darked rounded">Technology Stack</h2>
        </div>
        {data.sections.map((section, sectionIndex) => (
          <section class="skills-section relative group rounded-lg w-full p-3 xs:p-6 xs:px-10 transition duration-400 ease-out starting:opacity-0 starting:translate-y-2.5" style={`transition-delay: ${0.5 + sectionIndex * 0.1}s;`} data-section-index={sectionIndex} aria-labelledby={`skills-section-${sectionIndex}`}>
            <div class="absolute inset-0 rounded-lg bg-linear-to-r from-blue2/50 to-green2/50 opacity-20 transition-opacity duration-500 group-hover:opacity-50" aria-hidden="true" />
            <div class="relative flex flex-col gap-4">
              <h3 id={`skills-section-${sectionIndex}`} class="skills-section-title text-2xl xxs:text-3xl md:text-4xl text-center transition duration-400 ease-out delay-100 starting:opacity-0 starting:translate-y-2.5">
                {section.title}
              </h3>
              <div class="flex flex-wrap items-center justify-center gap-2 xs:gap-4 skill-container" role="list" aria-label={`${section.title} skills`}>
                {section.skills.map((skill, skillIndex) => (
                  <div title={skill.name} class="items-center justify-center p-0.5 rounded bg-linear-to-r from-ck1 to-ck2 skill-item transition-transform duration-300 hover:scale-105 hover:rotate-2 cursor-pointer" role="listitem" data-index={skillIndex}>
                    <div class="flex justify-center items-center py-1 px-2 gap-x-2 rounded whitespace-nowrap bg-buttonBg dark:bg-darker hover:bg-opacity-90 transition-all duration-300">
                      <Image src={skill.icon} alt={`${skill.name} technology icon`} class="w-6 h-6 xs:w-8 xs:h-8" loading={sectionIndex === 0 && skillIndex < 8 ? "eager" : "lazy"} fetchpriority={sectionIndex === 0 && skillIndex < 4 ? "high" : "auto"} decoding={sectionIndex === 0 ? "async" : "auto"} inferSize />
                      <p class="relative text-lg xs:text-xl whitespace-nowrap">{skill.name}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </section>
        ))}
      </>
    ) : (
      <Loading />
    )
  }
</RootLayout>

<script>
  // No JavaScript animations needed - using Tailwind starting: variant for entry transitions
</script>
