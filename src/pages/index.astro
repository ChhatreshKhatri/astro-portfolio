---
import { Image } from "astro:assets";
import LinkButton from "../components/LinkButton.astro";
import RootLayout from "../layouts/RootLayout.astro";
import Loading from "../components/Loading.astro";
import { getHomeData } from "../services/api";

const data = await getHomeData();
---

<RootLayout title="Chhatresh Khatri | Portfolio" description="Chhatresh Khatri Portfolio. Full stack Web Developer passionate about latest trends in the tech industry. Crafting innovation with code." keywords="" page="">
  <div class="flex items-center justify-center rounded p-0.5 bg-linear-to-r from-ck1 to-ck2 transition duration-400 ease-out starting:opacity-0 starting:-translate-y-2.5">
    <div class="flex justify-center items-center font-semibold tracking-wider text-xl xxs:text-2xl md:text-3xl p-1 px-2 bg-buttonBg dark:bg-darked rounded">Welcome to my Portfolio</div>
  </div>
  {
    data ? (
      <section class="hero-section relative group grid grid-cols-1 w-full lg:grid-cols-3 p-3 xs:p-6 xs:px-10 gap-1 xs:gap-4 lg:gap-8 transition duration-400 ease-out delay-100 starting:opacity-0 starting:translate-y-2.5" aria-labelledby="hero-heading">
        <div class="absolute inset-0 rounded-lg bg-linear-to-r from-blue2/50 to-green2/50 opacity-20 transition-opacity duration-500 group-hover:opacity-50" aria-hidden="true" />
        <article class="relative order-2 lg:order-1 lg:col-span-2 flex justify-center items-center rounded-lg">
          <div class="w-full flex flex-col justify-evenly gap-2 md:gap-4">
            <h1 id="hero-heading" class="hero-heading text-xl xxs:text-2xl xs:text-3xl md:text-5xl lg:text-5xl xl:text-6xl font-semibold text-center leading-tight transition duration-400 ease-out delay-200 starting:opacity-0 starting:translate-y-2.5">
              {data.intro}
            </h1>
            <div class="hero-typewriter text-xl xxs:text-2xl md:text-4xl xl:text-5xl font-semibold text-center min-h-[1.5em] leading-relaxed transition duration-400 ease-out delay-300 starting:opacity-0 starting:translate-y-2.5">
              <span id="autoType">Software Engineer</span>
              <span id="cursor" class="inline-block w-1 h-[1em] bg-current align-middle animate-pulse"></span>
            </div>
            <p class="hero-description text-base xs:text-lg md:text-xl text-justify leading-relaxed px-2 md:px-0 transition duration-400 ease-out delay-400 starting:opacity-0 starting:translate-y-2.5">{data.content}</p>
            <div class="hero-links flex flex-nowrap justify-center items-center gap-2 transition duration-400 ease-out delay-500 starting:opacity-0 starting:translate-y-2.5" aria-label="Social and portfolio links">
              {data.links.map((link, index) => (
                <div class="hero-link" data-index={index}>
                  <LinkButton name={link.type} link={link.url} imageUrl={link.icon} pos={index % 2} />
                </div>
              ))}
            </div>
          </div>
        </article>
        <aside class="hero-image order-1 lg:order-2 lg:col-span-1 flex justify-center items-center py-5 transition duration-400 ease-out delay-200 starting:opacity-0 starting:scale-[0.98]">
          <figure class="w-full h-full flex justify-center items-center">
            <Image 
              title="Chhatresh Khatri" 
              src={data.pic} 
              alt="Chhatresh Khatri" 
              class="w-[60%] xs:w-[50%] md:w-[35%] lg:w-full xl:w-[80%] drop-shadow-2xl" 
              loading="eager" 
              fetchpriority="high"
              decoding="async"
              width={512}
              height={512}
              style="will-change: opacity;"
            />
          </figure>
        </aside>
      </section>
    ) : (
      <Loading />
    )
  }
</RootLayout>

<script>
  const autoTypeElement = document.querySelector("#autoType");
  const words = ["Software Engineer", "Full Stack Developer", "Web Developer"];
  let wordIndex = 0;
  let charIndex = 0;

  function typeChar() {
    if (!autoTypeElement) return;
    if (charIndex < words[wordIndex].length) {
      autoTypeElement.textContent += words[wordIndex][charIndex++];
      setTimeout(typeChar, 150);
    } else {
      setTimeout(deleteChar, 2000);
    }
  }

  function deleteChar() {
    if (!autoTypeElement) return;
    if (charIndex > 0) {
      autoTypeElement.textContent = words[wordIndex].substring(0, --charIndex);
      setTimeout(deleteChar, 100);
    } else {
      wordIndex = (wordIndex + 1) % words.length;
      setTimeout(typeChar, 150);
    }
  }

  if (autoTypeElement) {
    autoTypeElement.textContent = "";
    setTimeout(typeChar, 500);
  }
</script>
