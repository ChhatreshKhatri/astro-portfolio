---
interface Props {
  page: string;
  link: string;
  ID: string;
}

const { page, link, ID } = Astro.props;
const currentPath = Astro.url.pathname;
const isActive = (currentPath === '/' && link === '/') || (link !== '/' && currentPath.startsWith(link));
---

<a 
  aria-label={`Navigate to ${page}`} 
  href={link} 
  aria-current={isActive ? 'page' : undefined}
  class="relative flex items-center justify-center group hover:text-ck1 dark:hover:text-ck2 transition-colors duration-200 cursor-pointer"
>
  {page}
  <span id={ID} class={`absolute h-0.5 bg-linear-to-r from-ck1 to-ck2 bottom-0 left-1/2 -translate-x-1/2 group-hover:w-full transition-[width] ease duration-300 ${isActive ? 'w-full' : 'w-0'}`}></span>
</a>
