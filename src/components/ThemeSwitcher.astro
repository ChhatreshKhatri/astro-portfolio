---
import MoonIcon from "../assets/icons/MoonIcon.astro";
import SunIcon from "../assets/icons/SunIcon.astro";
---

<button type="button" data-theme-toggle aria-label="Toggle theme" aria-live="polite" class="flex items-center justify-center cursor-pointer transition-transform duration-200 hover:scale-105 w-8">
  <span title="Switch to Dark Theme" class="sun hidden" aria-hidden="true">
    <SunIcon class="w-8 flex" />
  </span>
  <span title="Switch to Light Theme" class="moon hidden" aria-hidden="true">
    <MoonIcon class="w-8 flex" />
  </span>
</button>

<script is:inline>
  (() => {
    const mql = window.matchMedia("(prefers-color-scheme: dark)");
    let btn = null;
    let sun = null;
    let moon = null;

    const cacheElements = () => {
      btn = document.querySelector("[data-theme-toggle]");
      sun = btn?.querySelector(".sun");
      moon = btn?.querySelector(".moon");
    };

    const getTheme = () => localStorage.getItem("theme") || (mql.matches ? "dark" : "light");

    const applyTheme = (theme) => {
      const root = document.documentElement;
      root.classList.remove("dark", "light");
      root.classList.add(theme);

      btn?.setAttribute("aria-pressed", String(theme === "dark"));
      sun?.classList.toggle("hidden", theme !== "dark");
      moon?.classList.toggle("hidden", theme !== "light");
    };

    const bindThemeToggle = () => {
      if (!btn || btn.dataset.themeBound) return;
      btn.dataset.themeBound = "1";
      btn.addEventListener("click", () => {
        const nextTheme = getTheme() === "dark" ? "light" : "dark";
        localStorage.setItem("theme", nextTheme);
        applyTheme(nextTheme);
      });
    };

    const init = () => {
      cacheElements();
      bindThemeToggle();
      applyTheme(getTheme());
    };

    init();
    document.addEventListener("astro:after-swap", init);

    mql.addEventListener("change", (event) => {
      if (!localStorage.getItem("theme")) {
        applyTheme(event.matches ? "dark" : "light");
      }
    });
  })();
</script>
