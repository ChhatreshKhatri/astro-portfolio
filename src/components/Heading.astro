---
interface Props {
  as?: "h1" | "h2" | "div";
  class?: string;
};

const { as: Tag = "h1", class: classProp } = Astro.props;
---
    
<div class={`flex items-center justify-center rounded p-0.5 bg-linear-to-r from-ck1 to-ck2 transition duration-400 ease-out starting:opacity-0 starting:-translate-y-2.5 ${classProp ?? ""}`}>
  <Tag class="flex justify-center items-center font-semibold tracking-wider text-xl xxs:text-2xl md:text-3xl p-1 px-2 bg-buttonBg dark:bg-darked rounded">
    <slot />
  </Tag>
</div>
