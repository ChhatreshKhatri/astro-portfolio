{
  "compatibility_date": "2026-05-09",
  "compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
  "name": "astro-portfolio",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
  "keep_vars": true,
  "preview_urls": false,
  "workers_dev": false,
}
