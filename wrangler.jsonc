{
  "name": "astro-portfolio",
  "compatibility_date": "2025-06-17",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  },
  "keep_vars": true,
  "preview_urls": false,
  "workers_dev": false,
}
