{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "astro-portfolio",
  "compatibility_date": "2025-06-17",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "STATIC_ASSETS",
    "directory": "./dist/client"
  },
  "observability": {
    "enabled": true
  },
  "keep_vars": true,
  "preview_urls": false,
  "workers_dev": false,
  "pages_build_output_dir": "dist"
}
